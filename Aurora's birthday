<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Untuk Aurora 🤍</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Dancing+Script&display=swap');
    
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: linear-gradient(135deg, #ff9a9e, #fad0c4, #fad0c4, #ff9a9e);
      font-family: 'Playfair Display', serif;
      color: #fff;
      overflow-x: hidden;
      min-height: 100vh;
    }
    .container { max-width: 800px; margin: 0 auto; padding: 20px; text-align: center; }

    h1 {
      font-family: 'Dancing Script', cursive;
      font-size: 4.5rem;
      margin: 30px 0;
      text-shadow: 0 0 20px rgba(255,255,255,0.8);
    }

    .heart { position: absolute; font-size: 2rem; animation: float 15s infinite linear; opacity: 0.7; }
    @keyframes float {
      0% { transform: translateY(100vh) rotate(0deg); }
      100% { transform: translateY(-100vh) rotate(360deg); }
    }

    .section {
      background: rgba(255,255,255,0.2);
      margin: 30px 0;
      padding: 40px 30px;
      border-radius: 30px;
      backdrop-filter: blur(10px);
      box-shadow: 0 10px 30px rgba(0,0,0,0.2);
    }

    .gallery {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 15px;
      margin: 20px 0;
    }
    .gallery img {
      width: 100%;
      border-radius: 20px;
      transition: 0.4s;
    }
    .gallery img:hover { transform: scale(1.08) rotate(3deg); }

    button {
      background: #ff3366;
      color: white;
      border: none;
      padding: 15px 40px;
      font-size: 1.3rem;
      border-radius: 50px;
      cursor: pointer;
      margin: 20px;
      transition: 0.3s;
    }
    button:hover { transform: scale(1.1); background: #ff6699; }
  </style>
</head>
<body>
  <div class="container">
    <h1>Selamat Ulang Tahun, [Namanya]! 🤍</h1>
    
    <div class="section">
      <h2>💌 Pesan dari Aku</h2>
      <p style="font-size:1.4rem; line-height:1.8; margin:20px 0;">
        Kamu adalah alasan aku tersenyum setiap hari.<br>
        Terima kasih sudah jadi yang terbaik buat aku.<br>
        Semoga tahun ini penuh kebahagiaan dan cinta kita semakin kuat 💕
      </p>
    </div>

    <div class="section">
      <h2>🎵 Lagu Spesial</h2>
      <audio controls style="width:100%; margin:20px 0;">
        <source src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3" type="audio/mpeg">
      </audio>
      <p>(Ganti link lagu favorit kalian)</p>
    </div>

    <div class="section">
      <h2>📸 Kenangan Kita</h2>
      <div class="gallery">
        <!-- Ganti link foto kalian di sini -->
        <img src="https://picsum.photos/600/400?random=1" alt="kenangan 1">
        <img src="https://picsum.photos/600/400?random=2" alt="kenangan 2">
        <img src="https://picsum.photos/600/400?random=3" alt="kenangan 3">
        <img src="https://picsum.photos/600/400?random=4" alt="kenangan 4">
      </div>
    </div>

    <div class="section">
      <h2>🎂 Wishlist Tahun Ini</h2>
      <p>1. Selalu sehat & bahagia<br>
         2. Lebih banyak quality time bareng aku<br>
         3. Semua mimpi kamu tercapai</p>
    </div>

    <button onclick="alert('Aku cinta kamu selamanya 💖')">Klik Ini Sayang 💕</button>
  </div>

  <script>
    // Animasi hati jatuh
    function createHeart() {
      const heart = document.createElement('div');
      heart.classList.add('heart');
      heart.textContent = ['❤️','💖','💗','💘','💝'][Math.floor(Math.random()*5)];
      heart.style.left = Math.random() * 100 + 'vw';
      heart.style.animationDuration = Math.random() * 10 + 10 + 's';
      document.body.appendChild(heart);
      setTimeout(() => heart.remove(), 25000);
    }
    setInterval(createHeart, 400);
  </script>
</body>
</html>
