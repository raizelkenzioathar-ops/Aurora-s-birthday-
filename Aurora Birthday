<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Untuk Aurora 🤍</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Dancing+Script&display=swap');
    
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      background: linear-gradient(135deg, #ff9a9e 0%, #fad0c4 50%, #ff9a9e 100%);
      font-family: 'Playfair Display', serif;
      color: #fff;
      overflow-x: hidden;
      min-height: 100vh;
    }
    .container { max-width: 850px; margin: 0 auto; padding: 20px; text-align: center; }

    h1 {
      font-family: 'Dancing Script', cursive;
      font-size: 5rem;
      margin: 40px 0 20px;
      text-shadow: 0 0 30px rgba(255,255,255,0.9);
    }

    .heart { position: absolute; font-size: 2.2rem; animation: float 12s infinite linear; opacity: 0.8; z-index: -1; }
    @keyframes float {
      0% { transform: translateY(100vh) rotate(0deg); }
      100% { transform: translateY(-150vh) rotate(720deg); }
    }

    .section {
      background: rgba(255,255,255,0.25);
      margin: 35px 0;
      padding: 45px 35px;
      border-radius: 30px;
      backdrop-filter: blur(12px);
      box-shadow: 0 15px 35px rgba(0,0,0,0.25);
    }

    .gallery {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 15px;
      margin: 25px 0;
    }
    .gallery img {
      width: 100%;
      height: 220px;
      object-fit: cover;
      border-radius: 20px;
      transition: 0.4s;
      box-shadow: 0 5px 15px rgba(0,0,0,0.3);
    }
    .gallery img:hover { transform: scale(1.08) rotate(4deg); }
  </style>
</head>
<body>
  <div class="container">
    <h1>Selamat Ulang Tahun, Aurora! 🤍</h1>
    
    <div class="section">
      <h2>💌 Pesan dari Aku</h2>
      <p style="font-size:1.45rem; line-height:2; margin:25px 0;">
        Setiap hari bersamamu adalah hadiah terindah.<br>
        Terima kasih telah jadi alasan aku bahagia.<br>
        Semoga tahun ini semua keinginanmu tercapai 💕
      </p>
    </div>

    <div class="section">
      <h2>🎵 Lagu Spesial</h2>
      <audio controls autoplay loop style="width:90%; margin:20px 0;">
        <source src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-1.mp3" type="audio/mpeg">
      </audio>
    </div>

    <div class="section">
      <h2>📸 Kenangan Kita</h2>
      <div class="gallery">
        <img src="https://picsum.photos/600/400?random=1" alt="kenangan">
        <img src="https://picsum.photos/600/400?random=2" alt="kenangan">
        <img src="https://picsum.photos/600/400?random=3" alt="kenangan">
        <img src="https://picsum.photos/600/400?random=4" alt="kenangan">
      </div>
    </div>

    <button onclick="alert('Aku cinta kamu selamanya 💖')">Klik Kalau Kamu Sayang Aku 💕</button>
  </div>

  <script>
    function createHeart() {
      const heart = document.createElement('div');
      heart.classList.add('heart');
      heart.textContent = ['❤️','💖','💗','💘','💝'][Math.floor(Math.random()*5)];
      heart.style.left = Math.random() * 100 + 'vw';
      heart.style.animationDuration = (Math.random() * 8 + 10) + 's';
      document.body.appendChild(heart);
      setTimeout(() => heart.remove(), 30000);
    }
    setInterval(createHeart, 350);
  </script>
</body>
</html>
